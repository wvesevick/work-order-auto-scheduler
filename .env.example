# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Optional Google Maps keys
# Used by the backend for travel-time lookups.
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_DAILY_CALL_LIMIT=0
GOOGLE_MAPS_DEFAULT_TRAVEL_MINUTES=15

# Optional Postgres configuration
# If DB_ENGINE is not "postgres", SQLite (db.sqlite3) is used automatically.
DB_ENGINE=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
